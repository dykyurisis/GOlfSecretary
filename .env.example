# M0 스파이크 로컬 자격증명 — 절대 커밋 금지 (.env 는 .gitignore 됨)
# 이 파일(.env.example)을 복사해 .env 로 만들고 값을 채우세요:
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
#
# 우선 Dae Young Kim 의 Coto de Caza (invited facility 29) 계정만 입력
INVITED_USER=
INVITED_PW=

