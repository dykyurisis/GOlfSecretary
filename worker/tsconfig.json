{
  "compilerOptions": {
    "target": "ES2022", "module": "esnext", "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true, "esModuleInterop": true, "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true, "types": ["node"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
